# ============================================
# FRONTEND ENVIRONMENT VARIABLES
# ============================================

# API URL (backend) - SERVIDOR RENDER ONLINE
VITE_API_URL=https://auriplanoriginal-server.onrender.com/api

# WebSocket URL - SERVIDOR RENDER ONLINE (wss = WebSocket Secure)
VITE_WS_URL=wss://auriplanoriginal-server.onrender.com

# App Environment
VITE_APP_ENV=production

# Feature Flags - ATIVADOS (backend suporta todas)
VITE_ENABLE_AI=true
VITE_ENABLE_COLLABORATION=true
VITE_ENABLE_EXPORT=true
